generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tecnico {
  id           Int            @id @default(autoincrement())
  username     String         @unique @map("usuario")
  name         String         @map("nome")
  passwordHash String         @map("senhaHash")
  role         String         @default("technician") @map("cargo")
  active       Boolean        @default(true) @map("ativo")

  items        ItemOrdem[]
  auditLogs    LogAuditoria[]

  createdAt    DateTime       @default(now()) @map("criadoEm")
  updatedAt    DateTime       @updatedAt @map("atualizadoEm")

  @@map("tecnicos")
}

model Cliente {
  id        Int            @id @default(autoincrement())
  name      String         @map("nome")
  cpfCnpj   String?        @unique
  phone     String         @map("telefone")
  email     String?
  address   String?        @map("endereco")

  vehicles  Veiculo[]
  orders    OrdemServico[]

  createdAt DateTime       @default(now()) @map("criadoEm")
  updatedAt DateTime       @updatedAt @map("atualizadoEm")

  @@map("clientes")
}

model Veiculo {
  id        Int            @id @default(autoincrement())
  plate     String         @unique @map("placa")
  brand     String         @map("marca")
  model     String         @map("modelo")
  year      Int            @map("ano")
  color     String         @map("cor")
  chassis   String?        @map("chassi")
  mileage   Int            @map("quilometragem")

  clientId  Int            @map("clienteId")
  client    Cliente        @relation(fields: [clientId], references: [id])

  orders    OrdemServico[]

  createdAt DateTime       @default(now()) @map("criadoEm")
  updatedAt DateTime       @updatedAt @map("atualizadoEm")

  @@map("veiculos")
}

model OrdemServico {
  id             Int         @id @default(autoincrement())
  number         Int         @unique @map("numero")
  type           String      @default("BUDGET") @map("tipo")
  status         String      @default("OPEN")
  date           DateTime    @default(now()) @map("data")

  clientId       Int         @map("clienteId")
  client         Cliente     @relation(fields: [clientId], references: [id])

  vehicleId      Int         @map("veiculoId")
  vehicle        Veiculo     @relation(fields: [vehicleId], references: [id])

  defectReported String?     @map("defeitoRelatado")
  totalAmount    Float       @default(0) @map("valorTotal")
  notes          String?     @map("observacoes")

  items          ItemOrdem[]

  createdAt      DateTime    @default(now()) @map("criadoEm")
  updatedAt      DateTime    @updatedAt @map("atualizadoEm")

  @@map("ordens_servico")
}

model ItemOrdem {
  id         Int          @id @default(autoincrement())
  orderId    Int          @map("ordemServicoId")
  order      OrdemServico @relation(fields: [orderId], references: [id], onDelete: Cascade)

  description String      @map("descricao")
  quantity    Float       @default(1) @map("quantidade")
  unitPrice   Float       @map("precoUnitario")
  totalPrice  Float       @map("precoTotal")
  type        String      @default("SERVICE") @map("tipo")

  technicianId Int?       @map("tecnicoId")
  technician   Tecnico?   @relation(fields: [technicianId], references: [id], onDelete: SetNull)

  createdAt   DateTime    @default(now()) @map("criadoEm")
  updatedAt   DateTime    @updatedAt @map("atualizadoEm")

  @@map("itens_ordem")
}

model LogAuditoria {
  id           Int      @id @default(autoincrement())
  technicianId Int      @map("tecnicoId")
  technician   Tecnico  @relation(fields: [technicianId], references: [id])

  action       String   @map("acao")
  entity       String   @map("entidade")
  entityId     Int      @map("entidadeId")
  details      String?  @map("detalhes")
  timestamp    DateTime @default(now()) @map("dataHora")

  @@map("logs_auditoria")
}

model ItemCatalogo {
  id          Int      @id @default(autoincrement())
  description String   @map("descricao")
  type        String   @default("SERVICE") @map("tipo")
  costPrice   Float    @default(0) @map("precoCusto")
  unitPrice   Float    @default(0) @map("precoUnitario")
  stock       Int      @default(0) @map("estoque")
  active      Boolean  @default(true) @map("ativo")

  createdAt   DateTime @default(now()) @map("criadoEm")
  updatedAt   DateTime @updatedAt @map("atualizadoEm")

  @@map("itens_catalogo")
}
