# ──────────────────────────────────────────────────────────
#  V9 Orçamentos — variáveis de ambiente para produção
# ──────────────────────────────────────────────────────────

# Tipo do banco de dados: postgresql | mysql | sqlite
DB_TYPE=postgresql

# ── PostgreSQL (opção 1): URL completa — recomendado para Coolify ─────────────
# A URL deve apontar para o banco que será usado como MASTER (administradores e empresas).
# O sistema criará databases separados para cada empresa (v9_tenant_<cnpj>)
# na mesma instância PostgreSQL.
DATABASE_URL=postgresql://postgres:SENHA@HOST:5432/postgres

# ── PostgreSQL (opção 2): variáveis individuais ───────────────────────────────
# Use se preferir não usar DATABASE_URL
# PG_HOST=localhost
# PG_PORT=5432
# PG_USER=postgres
# PG_PASSWORD=
# PG_MASTER_DB=postgres

# Prefixo dos bancos tenant (padrão: v9_tenant_)
# PG_TENANT_PREFIX=v9_tenant_

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3001

# ── JWT ───────────────────────────────────────────────────────────────────────
# IMPORTANTE: troque por uma string longa e aleatória em produção
JWT_SECRET=mude-esta-chave-secreta-em-producao
